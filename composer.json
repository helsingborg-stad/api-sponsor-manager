{
    "name": "helsingborg-stad/api-sponsor-manager",
    "description": "Manages looking for sponsor listnings.",
    "type": "wordpress-plugin",
    "license": "MIT",
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit",
        "lint": "vendor/bin/mago lint",
        "fix": "vendor/bin/mago lint --format-after-fix --fix",
        "format": "vendor/bin/mago fmt"
    },
    "authors": [
        {
            "name": "Nikolas Ramsted",
            "email": "nikolas.ramstedt@helsingborg.se"
        }
    ],
    "autoload": {
        "psr-4": {
            "ApiSponsorManager\\": "source/php/"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "helsingborg-stad/wputilservice": "^0.2.44",
        "helsingborg-stad/wpservice": "^2.0",
        "helsingborg-stad/acfservice": "^1.0"
    },
    "suggest": {
        "helsingborg-stad/municipio": "^6.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "carthage-software/mago": "^1.6"
    },
    "config": {
        "allow-plugins": {
            "carthage-software/mago": true
        }
    }
}